# ScholarPress environment — copy to .env.local and fill in.

# --- Database (Supabase Postgres or local Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/scholarpress

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET=replace-with-a-strong-random-secret

# --- Google OAuth (https://console.cloud.google.com) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Sentry (optional in development; Chapter 8) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

NODE_ENV=development
